{
	"name": "robrowser",
	"version": "1.0.0",
	"scripts": {
		"serve": "vite preview",
		"live": "vite --open applications/browser-examples/demo.html",
		"pwa": "vite --open applications/pwa/index.html",
		"tools": "vite --open applications/tools/index.html",
		"nw": "nw .",
		"build": "node ./applications/tools/builder-web.mjs",
		"build:online": "npm run build -- -O",
		"build:mapviewer": "npm run build -- -V",
		"build:grfviewer": "npm run build -- -G",
		"build:modelviewer": "npm run build -- -M",
		"build:strviewer": "npm run build -- -S",
		"build:effectviewer": "npm run build -- -E",
		"build:threadhandler": "npm run build -- -T",
		"build:html": "npm run build -- -H",
		"build:ai": "npm run build -- -A",
		"build:all": "npm run build -- --all",
		"build:all:minify": "npm run build -- --all --m",
		"build:pwa": "npm run build -- --O --T --PWA",
		"build:nw": "build --concurrent --tasks win-x86,win-x64 --mirror https://dl.nwjs.io/ ./applications/nwjs",
		"lint": "eslint src/**/*.js",
		"lint:fix": "eslint src/**/*.js --fix",
		"lint:check": "eslint src/**/*.js --max-warnings 0",
		"dev": "vite",
		"build:vite": "vite build",
		"preview": "vite preview",
		"format": "prettier --write \"src/**/*.js\"",
		"format:check": "prettier --check \"src/**/*.js\"",
		"ci": "npm run lint && npm run format:check"
	},
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"author": "Vincent Thibault",
	"license": "GNU GPL V3",
	"devDependencies": {
		"@eslint/js": "^10.0.0",
		"@rollup/plugin-alias": "^6.0.0",
		"bson": "^7.2.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^16.0.0",
		"lodash": "^4.17.23",
		"nw": "^0.99.0-sdk",
		"nwjs-builder-phoenix": "^1.15.0",
		"prettier": "^3.8.1",
		"terser": "^5.19.4",
		"vite": "^8.0.1"
	},
	"build": {
		"nwVersion": "stable",
		"output": "./dist/Desktop",
		"packed": true,
		"targets": "zip",
		"files": [
			"**/*"
		]
	},
	"chromium-args": "--enable-webgl --ignore-gpu-blacklist --enable-node-worker --user-data-dir=save --disable-raf-throttling",
	"window": {
		"width": 1024,
		"height": 768,
		"fullscreen": false,
		"frame": true,
		"icon": "icon.png"
	},
	"main": "applications/nwjs/index.html"
}
