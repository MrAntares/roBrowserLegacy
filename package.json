{
	"name": "robrowser",
	"version": "2.0.0",
	"description": "Web-based Ragnarok Online client built with ES6 modules and WebGL",
	"scripts": {
		"serve": "vite preview",
		"live": "vite --open applications/browser-examples/demo.html",
		"pwa": "vite --open applications/pwa/index.html",
		"tools": "vite --open applications/tools/index.html",
		"build": "node ./applications/tools/builder-web.mjs",
		"build:online": "npm run build -- -O",
		"build:mapviewer": "npm run build -- -V",
		"build:grfviewer": "npm run build -- -G",
		"build:modelviewer": "npm run build -- -M",
		"build:strviewer": "npm run build -- -S",
		"build:effectviewer": "npm run build -- -E",
		"build:threadhandler": "npm run build -- -T",
		"build:html": "npm run build -- -H",
		"build:ai": "npm run build -- -A",
		"build:all": "npm run build -- --all",
		"build:all:minify": "npm run build -- --all --m",
		"build:pwa": "npm run build -- --O --T --PWA",
		"electron:dev": "electron applications/electron/main.js --dev",
		"electron:build": "electron-builder --config applications/electron/electron-builder.yml -w -l",
		"electron:build:win": "electron-builder --config applications/electron/electron-builder.yml --win",
		"electron:build:linux": "electron-builder --config applications/electron/electron-builder.yml --linux",
		"electron:build:mac": "electron-builder --config applications/electron/electron-builder.yml --mac",
		"electron": "electron applications/electron/main.js",
		"lint": "eslint src/**/*.js",
		"lint:fix": "eslint src/**/*.js --fix",
		"lint:check": "eslint src/**/*.js --max-warnings 0",
		"dev": "vite --open applications/browser-examples/demo.html",
		"build:vite": "vite build",
		"preview": "vite preview",
		"format": "prettier --write \"src/**/*.js\"",
		"format:check": "prettier --check \"src/**/*.js\"",
		"test": "vitest run",
		"ci": "npm run lint && npm run format:check"
	},
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"author": "Vincent Thibault",
	"license": "GNU GPL V3",
	"devDependencies": {
		"@eslint/js": "^10.0.0",
		"@rollup/plugin-alias": "^6.0.0",
		"electron": "^41.2.0",
		"electron-builder": "^26.8.1",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^16.0.0",
		"jsdom": "^29.0.1",
		"lodash": "^4.17.23",
		"prettier": "^3.8.1",
		"terser": "^5.19.4",
		"vite": "^8.0.1",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"lodash-es": "^4.18.1",
		"bson": "^7.2.0"
	}
}
