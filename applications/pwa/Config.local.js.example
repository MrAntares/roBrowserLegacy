// Config.local.js — copy this file, fill in your server details, and mount it:
//
//   cp applications/pwa/Config.local.js.example Config.local.js
//   # Edit Config.local.js with your server settings, then:
//   docker run -d --network host \
//     -v /path/to/your/Config.local.js:/robrowser/Config.local.js:ro \
//     ghcr.io/lenaxia/robrowserlegacy:<version>
//
// All settings here override the defaults in Config.js.
// Only specify the values you want to change.

window.ROConfigLocal = {
	servers: [
		{
			display: 'My RO Server',          // Name shown on server select screen
			desc: '',                          // Optional description
			address: '127.0.0.1',             // Login server IP or hostname
			port: 6900,                        // Login server port (default: 6900)
			version: 1,
			langtype: 1,
			packetver: 20200401,              // Must match your rAthena PACKETVER
			renewal: true,                    // true = Renewal, false = Pre-renewal/Classic
			packetKeys: false,
			socketProxy: 'ws://localhost:3338/ws/',  // WebSocket proxy — points at this container
			forceUseAddress: true,            // CRITICAL: prevents client using internal IPs
			                                  // returned by char/map server packets, which
			                                  // are unreachable in containerised deployments
			// adminList: [2000000],           // Optional: account IDs with GM commands enabled
		}
	],
	remoteClient: 'http://localhost:3338/',  // GRF asset server — points at this container
	skipIntro: false,                        // Set true to skip the intro video
	skipServerList: false,                   // Set true to auto-select the first server
	development: false,
	enableBank: true,
	enableCashShop: true,
	enableMapName: true,
	enableCheckAttendance: true,
	enableDmgSuffix: true,
};
